# Copy to .env and fill in real values for local development.
# Every variable the backend reads must be listed here (internal/config fails fast on missing required vars).

# --- Server ---
PING_PORT=8080
PING_ENV=development
# base URL the frontend and outbound links (e.g. email) use to reach the API
PING_BASE_URL=http://localhost:8080
# frontend origin allowed to make credentialed CORS requests to the API
CORS_ALLOWED_ORIGIN=http://localhost:3000

# --- Postgres (must match docker-compose.yml for local dev) ---
POSTGRES_USER=ping
POSTGRES_PASSWORD=ping
POSTGRES_DB=ping
DATABASE_URL=postgres://ping:ping@localhost:5432/ping?sslmode=disable

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth (JWT RS256) ---
# RSA keypair used to sign/verify access tokens; generate into backend/keys/ (gitignored), never commit.
# Paths are relative to backend/, the working directory the API process runs from (air / go run ./cmd/ping).
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
# false locks registration after the first account is created (see docs/DEVELOPMENT.md)
REGISTRATION_OPEN=true

# --- SMTP (alert delivery) ---
# Optional: leave SMTP_HOST blank to disable email (the "send test email"
# endpoint then reports that delivery is not configured). For local dev, the
# docker-compose mailpit sink accepts everything at localhost:1025 with no auth
# and shows captured mail at http://localhost:8025.
# Port 465 uses implicit TLS (SMTPS); any other port uses STARTTLS when offered.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=ping@example.com

# --- Prober (HTTP monitor SSRF guard) ---
# Optional: comma-separated CIDRs or bare IPs the SSRF dial-time guard allows
# even though they're private/loopback/link-local (e.g. genuinely internal
# self-hosted targets). Leave blank to fully enforce the guard (default).
# SSRF_ALLOWLIST=10.0.0.0/8,192.168.1.50

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
